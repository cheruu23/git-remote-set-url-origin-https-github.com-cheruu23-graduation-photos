{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/gallery/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*\\.(css|js|png|jpg|ico|svg|woff2?))", "dest": "frontend/$1" },
    { "src": "/admin.html", "dest": "frontend/admin.html" },
    { "src": "/", "dest": "frontend/index.html" }
  ]
}
